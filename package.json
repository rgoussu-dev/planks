{
  "name": "@rgoussu.dev/planks",
  "version": "0.2.1",
  "description": "Fundamental layout web components",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rgoussu-dev/planks.git"
  },
  "homepage": "https://rgoussu-dev.github.io/planks/",
  "bugs": {
    "url": "https://github.com/rgoussu-dev/planks/issues"
  },
  "main": "./dist/planks.umd.cjs",
  "module": "./dist/planks.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/planks.js",
      "require": "./dist/planks.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens": "./dist/tokens.css",
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --emitDeclarationOnly && cp src/styles/tokens.css dist/ && cp src/styles/styles.css dist/ && cp src/planks.d.ts dist/planks.d.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/html-vite": "^10.1.11",
    "happy-dom": "^20.9.0",
    "storybook": "^10.1.11",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "web-components",
    "layout",
    "every-layout",
    "css",
    "design-system"
  ],
  "license": "MIT"
}
